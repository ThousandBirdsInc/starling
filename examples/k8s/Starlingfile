# Local Kubernetes example for Starling, designed for a kind cluster.
#
#   kind create cluster --name starling
#   cd examples/k8s && starling up
#   open http://web-k8s.localhost:1360   (named URL via the proxy + a port_forward)
#
# Then edit app/index.html — live_update syncs it straight into the pod with no
# rebuild/redeploy.

docker_build(
    "starling-demo",
    "./app",
    live_update=[
        sync("./app/index.html", "/www/index.html"),
    ],
)

k8s_yaml("deploy.yaml")

k8s_resource(
    "web",
    port_forwards=["8080:8080"],
    labels={"example": "k8s"},
)
